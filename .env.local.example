# Supabase — entweder gehostetes Projekt (Dashboard → Project Settings → API)
# oder lokaler Stack via `supabase start` (CLI gibt die URL/Keys aus).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nur serverseitig (Server Actions). NICHT mit NEXT_PUBLIC_ prefixen.
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase-1-Stub: Calendar laeuft ohne diese Keys (MockCalendarProvider). ---
# Echtes Google-OAuth ist erst spaeter noetig (siehe lib/calendar/google.ts).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Welcher Calendar-Provider aktiv ist: "mock" (default) | "google"
CALENDAR_PROVIDER=mock
